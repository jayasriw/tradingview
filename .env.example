# ── Claude / Anthropic ───────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_api_key_here

# Set to "true" to run without a real API key (returns canned responses)
MOCK_ANALYSIS=false

# ── Webhook security ─────────────────────────────────────────────────────────
# Optional: add ?token=YOUR_SECRET to your TradingView webhook URL
WEBHOOK_SECRET=

# ── Notifications: Telegram ──────────────────────────────────────────────────
# 1. Create a bot via @BotFather → copy the token
# 2. Add the bot to your channel/group → get the chat id with:
#    curl https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Notifications: Slack ─────────────────────────────────────────────────────
# Create an Incoming Webhook at https://api.slack.com/apps
SLACK_WEBHOOK_URL=

# ── Storage ──────────────────────────────────────────────────────────────────
DB_PATH=alerts.db

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
